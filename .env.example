# Synapse — voice cascade M0. Copy this file to .env and fill in real values.
# .env is gitignored; never commit real keys.

# Optional, not required by the cascade or the voice pipeline. Google's own OpenAI-compat
# endpoint mangled function-calling on multi-turn tool round-trips, so tier1 now runs through
# OpenRouter instead (see below).
GOOGLE_API_KEY=

# Models used by tools/bench_llm_providers.py. Keep these aligned: the
# OpenRouter identifier carries the routing-provider prefix.
GEMINI_MODEL=gemini-3.5-flash
OPENROUTER_MODEL=google/gemini-3.5-flash

# Cascade tier 1 — OpenRouter, google/gemini-3.5-flash (primary). Get a key at
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cascade tier 2 — Anthropic, claude-haiku-4-5, the fallback (Р-14). Get a key at
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# STT — Deepgram Flux (candidate, §7 №5 decides). Get a key at https://console.deepgram.com
DEEPGRAM_API_KEY=

# TTS — Fish Audio s2-pro websocket (candidate, §7 smoke-test decides). Voice already used in
# this repo's tg.py (Гаврилов). Get a key at https://fish.audio
FISH_AUDIO_API_KEY=
FISH_REFERENCE_ID=

# TTS model — s2.1-pro-free is free through end of July 2026; requests may go into training
# data (class of assumption §11.4). Leave unset to use this same default.
FISH_TTS_MODEL=s2.1-pro-free
