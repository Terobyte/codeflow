# Synapse — voice cascade M0. Copy this file to .env and fill in real values.
# .env is gitignored; never commit real keys.

# Cascade tier 1 — Google AI Studio, gemini-3.5-flash, OpenAI-compatible endpoint (free tier
# by default — see docs/superpowers/specs/2026-07-08-synapse-m0-voice-cascade-design.md §11.4).
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Cascade tier 2 — OpenRouter, same model (google/gemini-3.5-flash), used when Google's own
# quota is exhausted (Р-14). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cascade tier 3 — Anthropic, claude-haiku-4-5, the tail of the cascade (outside Google's
# infra entirely). Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# STT — Deepgram Flux (candidate, §7 №5 decides). Get a key at https://console.deepgram.com
DEEPGRAM_API_KEY=

# TTS — Fish Audio s2-pro websocket (candidate, §7 smoke-test decides). Voice already used in
# this repo's tg.py (Гаврилов). Get a key at https://fish.audio
FISH_AUDIO_API_KEY=
FISH_REFERENCE_ID=
